# NOBLE-CERT BACKEND — Environment Variables

# App
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database (MongoDB) — Dùng Docker: docker run -d --name noble-mongo -p 27017:27017 mongo:7 --replSet rs0
# Sau đó chạy: docker exec noble-mongo mongosh --eval 'rs.initiate()'
MONGODB_URI=mongodb://localhost:27017/noble-cert-dev?directConnection=true

# Redis — Dùng Docker: docker run -d --name redis -p 6379:6379 redis:alpine
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your_super_secret_access_key_change_me_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_me_in_production
JWT_REFRESH_EXPIRES_IN=7d

# PayOS Payment Gateway (https://payos.vn)
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
