# Environment
NODE_ENV=development
PORT=5000

# MongoDB (database name is derived from NODE_ENV in env.config.ts)
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net
MONGODB_URI=mongodb://localhost:27017/noble-cert-dev

# Client URLs (CORS + redirects)
CLIENT_URL=http://localhost:3000
ADMIN_CLIENT_URL=http://localhost:3001

# JWT access token
JWT_SECRET=replace-with-strong-random-string
JWT_EXPIRES_IN=15m

# JWT refresh token
JWT_REFRESH_SECRET=replace-with-strong-random-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# PayOS (sandbox / test keys)
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# VietQR
VIETQR_CLIENT_ID="098765your-vietqr-client-id4321"
VIETQR_API_KEY="098765your-vietqr-api-key4321"

