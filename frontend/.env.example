# NOBLE-CERT FRONTEND — Environment Variables

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:5000

# App URL (for metadata, SEO)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth.js
AUTH_SECRET=your-auth-secret-change-me-in-production
AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# VietQR — Thông tin tài khoản ngân hàng nhận thanh toán
# Mã ngân hàng: VCB, MB, TCB, ACB, TPB, BIDV, ... (https://vietqr.io/danh-sach-ngan-hang)
NEXT_PUBLIC_BANK_ID=MB
NEXT_PUBLIC_ACCOUNT_NO=0000000000000
NEXT_PUBLIC_ACCOUNT_NAME=TEN CHU TAI KHOAN
